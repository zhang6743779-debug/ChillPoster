# === 排除系统与缓存文件 ===
__pycache__
*.pyc
*.pyo
*.pyd
venv/
.venv/
.env
scripts/deploy-nas-dev.env
.git
.gitignore
.idea
.vscode
.claude/
.DS_Store
*.bak
*.original
*备份*
frontend/node_modules/
frontend/dist/
static/index 完整提示.html

# === 排除 Docker 自身配置 ===
Dockerfile
docker-compose.yml
.dockerignore

# === 排除敏感配置与数据 ===
# 镜像里应该只有代码，配置应该通过挂载卷 (Volume) 映射进去
config/*.json
config/*.log
config/app.log
config/*.log.*
config/*.jsonl
config/*.db
config/*.db-journal
config/*.db-wal
config/*.db-shm
config/telegram_user.session*
config/telegram_avatars/
!config/media_organize_category_rules.json

# 排除本地产生的备份、测试脚本和字体缓存
backups/
test_*.py

# 排除无关的外部项目目录
MoviePilot-2.10.6/
MoviePilot-Frontend-2.10.5/
# (保留 fonts/ 目录结构但排除其他字体，或者根据需求保留)
