# Copy this file to scripts/deploy-nas-dev.env and fill in your NAS details.
# The real deploy-nas-dev.env file is ignored by Git.

# SSH target for your NAS.
NAS_SSH_TARGET="your-user@192.168.1.100"
NAS_SSH_PORT="22"

# Directory on the NAS that contains docker-compose.yml / compose.yaml.
NAS_COMPOSE_DIR="/volume1/docker/chillposter"

# Compose service name for ChillPoster. Leave empty to recreate the whole compose project.
NAS_COMPOSE_SERVICE="chillposter"

# Target platform for the NAS. Most Intel/AMD NAS devices use linux/amd64.
# Some ARM NAS devices may need linux/arm64.
NAS_PLATFORM="linux/amd64"

# Local and remote image tag used for dev testing.
# Your compose file must reference this image, or you must set CHILLPOSTER_IMAGE
# in the compose env and use image: ${CHILLPOSTER_IMAGE:-chillne/chillposter:latest}
NAS_IMAGE_NAME="chillposter:dev"

# Published release image used as the dependency/runtime base. Keep this
# different from NAS_IMAGE_NAME so repeated dev builds do not stack layers.
NAS_BASE_IMAGE="chillne/chillposter:v4.8.5.7"
NAS_BASE_PULL="missing"

# Fast local test image: overlays source on top of the published runtime image.
# Use "Dockerfile" only if you specifically want to test the protected release build.
NAS_DOCKERFILE="Dockerfile.dev-nas"

# Docker/Compose commands on the NAS. Change to "sudo docker" if needed.
NAS_DOCKER_CMD="docker"
NAS_COMPOSE_CMD="docker compose"

# Optional extra build args, for example:
# NAS_BUILD_ARGS="--no-cache"
NAS_BUILD_ARGS=""
